{
  "openapi": "3.0.0",
  "info": { "title": "Ref Test", "version": "2.0.0" },
  "components": {
    "schemas": {
      "Address": {
        "type": "object",
        "properties": {
          "street": { "type": "string" }
        }
      },
      "Pet": {
        "type": "object",
        "properties": {
          "name":    { "type": "integer" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      }
    }
  },
  "paths": {
    "/pets/{id}": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Pet" }
              }
            }
          }
        }
      }
    }
  }
}
